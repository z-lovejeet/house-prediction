# ═══════════════════════════════════════════════════════════
# House Price Prediction — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Generated Outputs (regenerated by pipeline) ─────────
# These are large files produced by running the pipeline.
# Anyone can regenerate them with: python run_pipeline.py
backend/ml_pipeline/outputs/processed/
backend/ml_pipeline/outputs/baseline/
backend/ml_pipeline/outputs/advanced_models/
backend/ml_pipeline/outputs/eda/
backend/ml_pipeline/outputs/optimization/

# ── Serialized Models ────────────────────────────────────
*.pkl
*.joblib
*.h5

# ── Data (too large for GitHub) ──────────────────────────
# The dataset is publicly available on Kaggle.
# See README.md for download instructions.
data/*.csv

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter Notebooks (if any) ───────────────────────────
.ipynb_checkpoints/

# ── PDF exports (generated from HTML report) ─────────────
docs/*.pdf

# ── Miscellaneous ────────────────────────────────────────
*.log
*.tmp
.env
