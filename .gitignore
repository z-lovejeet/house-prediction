# ═══════════════════════════════════════════════════════════
# House Price Prediction — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Generated Outputs (regenerated by pipeline) ─────────
# These are small enough to commit for Render deployment
# backend/ml_pipeline/outputs/processed/
# backend/ml_pipeline/outputs/baseline/
# backend/ml_pipeline/outputs/advanced_models/
# backend/ml_pipeline/outputs/eda/
# backend/ml_pipeline/outputs/optimization/

# ── Serialized Models ────────────────────────────────────
# *.pkl
# *.joblib
# *.h5

# ── Data (too large for GitHub) ──────────────────────────
# The dataset is publicly available on Kaggle.
# We are committing it so Render has access to the raw data.
# data/*.csv

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter Notebooks (if any) ───────────────────────────
.ipynb_checkpoints/

# ── PDF exports (generated from HTML report) ─────────────
docs/*.pdf

# ── Node.js / Next.js (Frontend) ─────────────────────────
node_modules/
.next/
.vercel/
*.tsbuildinfo
next-env.d.ts

# ── Miscellaneous ────────────────────────────────────────
*.log
*.tmp
.env
.env*
